{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "theme": "dark",
  "permissionMode": "plan",
  "includeCoAuthoredBy": false,
  "preferredNotifChannel": "terminal_bell",
  "spinnerTipsEnabled": false,
  "autoUpdatesChannel": "stable",
  "cleanupPeriodDays": 90,
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:sentry.io)",
      "Bash(git push *--force*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * -f)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push --mirror *)",
      "Bash(git filter-branch *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs*)"
    ],
    "ask": [
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/agentic/hooks/context-guard.sh"
          }
        ]
      }
    ]
  },
  "claudeMdExcludes": [
    "**/node_modules/**/CLAUDE.md",
    "**/vendor/**/CLAUDE.md",
    "**/.opencode/**",
    "**/.cursor/**",
    "**/.windsurf/**"
  ]
}

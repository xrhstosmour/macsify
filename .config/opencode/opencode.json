{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "default_agent": "leader",
  "autoupdate": true,
  "instructions": [
    "~/.config/opencode/instructions/standards.md",
    "~/.config/opencode/instructions/versioning.md",
    "~/.config/opencode/instructions/communication.md",
    "~/.config/opencode/tools/github.md",
    "~/.config/opencode/tools/phabricator.md",
    "~/.config/opencode/tools/sentry.md",
    "~/.config/opencode/tools/qmd.md"
  ],
  "permission": {
    "bash": {
      "*": "allow",
      "git push*": "allow",
      "git push*--force*": "deny",
      "git push*-f*": "deny",
      "git push*main*": "deny",
      "git push*master*": "deny",
      "git push*--mirror*": "deny",
      "git reset*--hard*": "ask",
      "git clean*-f*": "ask",
      "git branch*-D*": "ask",
      "git filter-branch*": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "rm -rf $HOME*": "deny",
      "sudo*": "deny",
      "dd *": "deny",
      "mkfs*": "deny"
    }
  },
  "watcher": {
    "ignore": [
      "**/.DS_Store",
      "**/Thumbs.db",
      "**/._*",
      "**/.Spotlight-V100",
      "**/.Trashes",
      "**/.fseventsd",
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "__pycache__/**",
      "*.pyc",
      ".venv/**",
      "venv/**",
      "env/**",
      "vendor/**",
      ".idea/**",
      "*.swp",
      "*.swo",
      "*~",
      ".gradle/**",
      "*.class",
      "*.jar",
      "*.war",
      "target/**",
      ".sbt/**",
      "*.egg-info/**",
      ".tox/**",
      ".nox/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".pytest_cache/**",
      "*.spec.js",
      "*.spec.ts",
      "*.test.js",
      "*.test.ts",
      "coverage/**",
      ".nyc_output/**",
      ".next/**",
      ".nuxt/**",
      ".output/**",
      ".cache/**",
      "*.tsbuildinfo",
      ".parcel-cache/**",
      ".turbo/**",
      "*.lock.bak",
      "*.lock",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "bun.lockb",
      "composer.lock",
      "go.sum",
      "Cargo.lock",
      "*.pot",
      "*.po",
      "*.mo",
      ".sass-cache/**",
      ".npm/**",
      ".yarn/**",
      ".pnpm-store/**",
      ".browserslistrc",
      ".babelrc",
      "*.min.js",
      "*.min.css",
      "*.log",
      "logs/**",
      ".wrangler/**",
      ".vercel/**",
      ".serverless/**",
      ".dynamodb/**",
      ".esbuild/**",
      ".tflog/**",
      ".claude/**",
      ".cursor/**",
      ".windsurf/**",
      ".github/**",
      ".env",
      ".env.*",
      "!.env.example",
      "*.local",
      ".tmp/**",
      ".temp/**",
      "*.tmp",
      "*.temp",
      "Thumbs.db",
      ".AppleDouble",
      ".LSOverride",
      ".DocumentRevisions-V100",
      ".com.apple.timemachine.donotpresent"
    ]
  }
}

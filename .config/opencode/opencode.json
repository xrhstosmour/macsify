{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "autoupdate": true,
  "instructions": [
    "~/.config/opencode/INSTRUCTIONS.md"
  ],
  "watcher": {
    "ignore": [
      "**/.DS_Store",
      "**/Thumbs.db",
      "**/._*",
      "**/.Spotlight-V100",
      "**/.Trashes",
      "**/.fseventsd",
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "__pycache__/**",
      "*.pyc",
      ".venv/**",
      "venv/**",
      "env/**",
      "vendor/**",
      ".idea/**",
      "*.swp",
      "*.swo",
      "*~",
      ".gradle/**",
      "*.class",
      "*.jar",
      "*.war",
      "target/**",
      ".sbt/**",
      "*.egg-info/**",
      ".tox/**",
      ".nox/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      ".pytest_cache/**",
      "*.spec.js",
      "*.spec.ts",
      "*.test.js",
      "*.test.ts",
      "coverage/**",
      ".nyc_output/**",
      ".next/**",
      ".nuxt/**",
      ".output/**",
      ".cache/**",
      "*.tsbuildinfo",
      ".parcel-cache/**",
      ".turbo/**",
      "*.lock.bak",
      "*.lock",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "bun.lockb",
      "composer.lock",
      "go.sum",
      "Cargo.lock",
      "*.pot",
      "*.po",
      "*.mo",
      ".sass-cache/**",
      ".npm/**",
      ".yarn/**",
      ".pnpm-store/**",
      ".browserslistrc",
      ".babelrc",
      "*.min.js",
      "*.min.css"
    ]
  }
}
